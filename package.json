{
  "name": "gh-upload-sbom",
  "version": "2.0.0",
  "description": "Publishes BOMs to Dependency-Track from GitHub Actions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DependencyTrack/gh-upload-sbom"
  },
  "license": "Apache-2.0",
  "main": "index.js",
  "files": [
    "action.yml",
    "dist"
  ],
  "scripts": {
    "build": "ncc build index.js --minify --no-cache --target es2022 -o dist",
    "prettier": "prettier --ignore-path .gitignore \"./**/*.{js,json,md,ts,yml}\""
  },
  "dependencies": {
    "@actions/core": "^1.10.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.2.0",
    "@vercel/ncc": "^0.38.0",
    "prettier": "^3.0.3",
    "prettier-plugin-packagejson": "^2.4.5"
  }
}
